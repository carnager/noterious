{
  "name": "noterious",
  "version": "1.0.0",
  "description": "Noterious is a server-first, markdown-backed knowledge base designed for fast clients, structured queries, and companion/mobile integrations.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:ui": "npm run typecheck && npm run build:ui:app && npm run build:ui:editor",
    "build:ui:app": "esbuild frontend/app.ts --bundle --format=iife --platform=browser --target=es2020 --outfile=internal/httpapi/static/app.js",
    "build:ui:editor": "esbuild frontend/editor.ts --bundle --format=iife --platform=browser --target=es2020 --outfile=internal/httpapi/static/editor.bundle.js",
    "verify:ui": "npm run build:ui && git diff --exit-code -- internal/httpapi/static/app.js internal/httpapi/static/editor.bundle.js",
    "test:ui": "vitest run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/highlight": "^0.19.8",
    "@codemirror/history": "^0.19.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "esbuild": "^0.28.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
